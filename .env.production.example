# ══════════════════════════════════════════════════════
#   باندا - إعدادات الإنتاج (Hostinger + Neon PostgreSQL)
#   ⚠️  أدخل هذه القيم في "Environment Variables" بلوحة
#       Hostinger Node.js - لا ترفع هذا الملف بقيم حقيقية
# ══════════════════════════════════════════════════════

APP_ENV=production
PORT=3000

# ─── قاعدة البيانات (Neon - استخدم connection string الكامل) ───
# مثال: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=postgresql://neondb_owner:CHANGE_ME_PASSWORD@ep-wild-math-a2hay4jo-pooler.eu-central-1.aws.neon.tech/CHANGE_ME_DBNAME?sslmode=require

# ─── الأمان (غيّر هذه القيم!) ───
COOKIE_SECRET=CHANGE_ME_random_string_min_32_characters
SUPERADMIN_USERNAME=CHANGE_ME_admin_username
SUPERADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# ─── الروابط (استبدل بنطاقك) ───
STOREFRONT_URL=https://CHANGE_ME.com
ASSET_URL_PREFIX=https://CHANGE_ME.com/assets/

# ─── البريد ───
FROM_EMAIL="باندا" <noreply@CHANGE_ME.com>
